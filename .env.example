# Sarayah — environment variables
# Copy this file to .env.local and fill in real values. NEVER commit .env.local.
# Do not put real keys in this example file.

# --- Supabase (required) ---
# Supabase dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_or_publishable_key_here

# --- Admin access (required for /admin) ---
# Comma-separated emails allowed into /admin. Must ALSO be added to the `admins`
# table in Supabase (see supabase_schema.sql) so RLS grants them access.
ADMIN_EMAILS=you@example.com

# --- Site URL (optional, for correct Open Graph/SEO links in production) ---
# NEXT_PUBLIC_SITE_URL=https://sarayah.example.com

# --- Email notifications via Resend (optional) ---
# Without RESEND_API_KEY, leads/venues still save; they just don't email anyone.
# Get a key at https://resend.com -> API Keys. See docs/pre-launch-checklist.md.
RESEND_API_KEY=your_resend_api_key_here
ADMIN_NOTIFICATION_EMAIL=your_admin_email@example.com
LEAD_NOTIFY_FROM=Sarayah <onboarding@resend.dev>

# --- Rate limiting via Upstash Redis (optional) ---
# Without these, rate limiting is disabled (app still runs). Create a free Redis at
# https://upstash.com and copy the REST URL + token. See docs/pre-launch-checklist.md.
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token_here

# --- AI search via Claude (optional) ---
# Without a key, search falls back to the offline keyword parser.
# Get a key at https://console.anthropic.com.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-opus-4-8   # or claude-haiku-4-5 for cheaper/faster parsing

# ============================================================================
# n8n automation — OPTIONAL / POST-LAUNCH. NOT required to deploy or run the app.
# Leave every variable below BLANK for the MVP. With them blank, n8n is fully
# disabled: leads/venues still save to Supabase (the source of truth) and nothing
# breaks. Only fill these in later if you decide to add n8n automation.
# ============================================================================

# --- n8n + WhatsApp outreach (optional, post-launch) ---
# Used by the semi-automated venue outreach (see docs/n8n-whatsapp-outreach.md).
# WhatsApp Business Cloud API (NOT personal WhatsApp). Tokens are server-only —
# never reference them in client components.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
# Shared secret. Used BOTH ways:
#  - inbound: n8n must send it (x-n8n-secret header) to the /api/outreach/* routes;
#  - outbound: the app sends it (x-webhook-secret header) when mirroring new leads /
#    pending venues to n8n → Google Sheets (see docs/n8n-supabase-to-sheets.md).
N8N_WEBHOOK_SECRET=

# --- n8n → Google Sheets mirror (optional, post-launch, one-way) ---
# Webhook URL of your n8n workflow that appends new leads / pending venues to a
# Google Sheet. LEAVE BLANK for the MVP — the mirror is a no-op when unset and the
# app works normally. See docs/n8n-supabase-to-sheets.md.
N8N_WEBHOOK_URL=

# NOTE: This app intentionally uses NO service-role/secret key. Privileged admin
# actions run server-side using the logged-in admin's session (RLS enforces access).
